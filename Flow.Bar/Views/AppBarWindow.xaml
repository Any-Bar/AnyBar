<Window
    x:Class="Flow.Bar.Views.AppBarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Flow.Bar.Controls"
    xmlns:converters="clr-namespace:Flow.Bar.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enum="clr-namespace:Flow.Bar.Models.Enums"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:local="clr-namespace:Flow.Bar"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Flow.Bar.Models.AppBar"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewModels="clr-namespace:Flow.Bar.ViewModels"
    Width="800"
    Height="450"
    d:DataContext="{d:DesignInstance viewModels:AppBarViewModel}"
    ui:ThemeManager.IsThemeAware="True"
    ui:ThemeManager.RequestedTheme="Default"
    ui:TitleBar.ExtendViewIntoTitleBar="True"
    ui:TitleBar.Height="0"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True"
    Closing="Window_Closing"
    DpiChanged="Window_DpiChanged"
    Loaded="Window_Loaded"
    SourceInitialized="Window_SourceInitialized"
    mc:Ignorable="d">
    <Window.Resources>
        <converters:BarElementModelConverterToFrameworkElement x:Key="BarElementModelConverterToFrameworkElement" />
    </Window.Resources>

    <Grid
        x:Name="MainGrid"
        Background="Transparent"
        PreviewMouseRightButtonDown="MainGrid_PreviewMouseRightButtonDown"
        PreviewMouseRightButtonUp="MainGrid_PreviewMouseRightButtonUp">
        <Thumb x:Name="BarThumb">
            <Thumb.Style>
                <Style TargetType="{x:Type Thumb}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Thumb">
                                <Border
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}"
                                    HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                    Background="{DynamicResource AppBarSeparatorForeground}"
                                    BorderThickness="0"
                                    Cursor="{TemplateBinding Cursor}" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Cursor" Value="Arrow" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Top}" />
                                <Condition Binding="{Binding IsResizable}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Cursor" Value="SizeNS" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Bottom}" />
                                <Condition Binding="{Binding IsResizable}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Cursor" Value="SizeNS" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Left}" />
                                <Condition Binding="{Binding IsResizable}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Cursor" Value="SizeWE" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Right}" />
                                <Condition Binding="{Binding IsResizable}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Cursor" Value="SizeWE" />
                        </MultiDataTrigger>
                        <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Top}">
                            <Setter Property="Height" Value="2" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="VerticalAlignment" Value="Bottom" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Bottom}">
                            <Setter Property="Height" Value="2" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="VerticalAlignment" Value="Top" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Left}">
                            <Setter Property="Width" Value="2" />
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Right}">
                            <Setter Property="Width" Value="2" />
                            <Setter Property="HorizontalAlignment" Value="Left" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Thumb.Style>
        </Thumb>

        <Grid x:Name="BarElementsGrid" Background="Transparent">
            <Grid.Style>
                <Style TargetType="{x:Type Grid}">
                    <Setter Property="Margin" Value="8 0 8 2" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Bottom}">
                            <Setter Property="Margin" Value="8 2 8 0" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Left}">
                            <Setter Property="Margin" Value="0 8 2 8" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Right}">
                            <Setter Property="Margin" Value="2 8 0 8" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <DockPanel
                x:Name="EdgeBarElementsDockPanel"
                Background="Transparent"
                LastChildFill="False">
                <controls:StackView
                    x:Name="LeftOrTopStackView"
                    CanReorderItems="False"
                    ItemsSource="{Binding LeftOrTopBarElements, Mode=OneWay}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <controls:StackView.Style>
                        <Style BasedOn="{StaticResource DefaultStackViewStyle}" TargetType="controls:StackView">
                            <Setter Property="HorizontalAlignment" Value="Left" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Orientation" Value="Horizontal" />
                            <Setter Property="DockPanel.Dock" Value="Left" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Left}">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Top" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalContentAlignment" Value="Top" />
                                    <Setter Property="Orientation" Value="Vertical" />
                                    <Setter Property="DockPanel.Dock" Value="Top" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Right}">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Top" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalContentAlignment" Value="Top" />
                                    <Setter Property="Orientation" Value="Vertical" />
                                    <Setter Property="DockPanel.Dock" Value="Top" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:StackView.Style>

                    <controls:StackView.ItemTemplate>
                        <DataTemplate DataType="models:BarElementModel">
                            <ContentControl Content="{Binding ., Converter={StaticResource BarElementModelConverterToFrameworkElement}}" />
                        </DataTemplate>
                    </controls:StackView.ItemTemplate>
                </controls:StackView>

                <controls:StackView
                    x:Name="RightOrBottomStackView"
                    CanReorderItems="False"
                    ItemsSource="{Binding CenterBarElements, Mode=OneWay}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <controls:StackView.Style>
                        <Style BasedOn="{StaticResource DefaultStackViewStyle}" TargetType="controls:StackView">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Orientation" Value="Horizontal" />
                            <Setter Property="DockPanel.Dock" Value="Right" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Left}">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Bottom" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalContentAlignment" Value="Top" />
                                    <Setter Property="Orientation" Value="Vertical" />
                                    <Setter Property="DockPanel.Dock" Value="Bottom" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Right}">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Bottom" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalContentAlignment" Value="Top" />
                                    <Setter Property="Orientation" Value="Vertical" />
                                    <Setter Property="DockPanel.Dock" Value="Bottom" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:StackView.Style>

                    <controls:StackView.ItemTemplate>
                        <DataTemplate DataType="models:BarElementModel">
                            <ContentControl Content="{Binding ., Converter={StaticResource BarElementModelConverterToFrameworkElement}}" />
                        </DataTemplate>
                    </controls:StackView.ItemTemplate>
                </controls:StackView>
            </DockPanel>

            <controls:StackView
                x:Name="CenterStackView"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CanReorderItems="False"
                ItemsSource="{Binding CenterBarElements, Mode=OneWay}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <controls:StackView.Style>
                    <Style BasedOn="{StaticResource DefaultStackViewStyle}" TargetType="controls:StackView">
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="Orientation" Value="Horizontal" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Left}">
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="VerticalContentAlignment" Value="Top" />
                                <Setter Property="Orientation" Value="Vertical" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Right}">
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="VerticalContentAlignment" Value="Top" />
                                <Setter Property="Orientation" Value="Vertical" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:StackView.Style>

                <controls:StackView.ItemTemplate>
                    <DataTemplate DataType="models:BarElementModel">
                        <ContentControl Content="{Binding ., Converter={StaticResource BarElementModelConverterToFrameworkElement}}" />
                    </DataTemplate>
                </controls:StackView.ItemTemplate>
            </controls:StackView>
        </Grid>
    </Grid>
</Window>