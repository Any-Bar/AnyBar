<Window
    x:Class="Flow.Bar.Views.AppBarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:local="clr-namespace:Flow.Bar"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Width="800"
    Height="450"
    ui:ThemeManager.IsThemeAware="True"
    ui:ThemeManager.RequestedTheme="Default"
    ui:TitleBar.ExtendViewIntoTitleBar="True"
    ui:TitleBar.Height="0"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True"
    Closing="Window_Closing"
    DpiChanged="Window_DpiChanged"
    Loaded="Window_Loaded"
    SourceInitialized="Window_SourceInitialized"
    mc:Ignorable="d">
    <Window.Resources>
        <Style x:Key="NoHoverThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid
        x:Name="MainGrid"
        Background="Transparent"
        PreviewMouseRightButtonDown="MainGrid_PreviewMouseRightButtonDown"
        PreviewMouseRightButtonUp="MainGrid_PreviewMouseRightButtonUp">
        <DockPanel Background="Transparent" LastChildFill="False">
            <Thumb
                x:Name="BarThumb"
                Height="2"
                Background="{DynamicResource AppBarSeparatorForeground}"
                BorderThickness="0"
                Cursor="Arrow"
                DockPanel.Dock="Bottom"
                Foreground="{DynamicResource AppBarSeparatorForeground}"
                Style="{StaticResource NoHoverThumbStyle}" />
        </DockPanel>

        <Grid
            x:Name="PluginControlGrid"
            Margin="8 0 8 5"
            Background="Transparent">

            <Grid Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ikw:SimpleStackPanel
                    x:Name="LeftOrTopStackPanel"
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Background="Transparent"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock VerticalAlignment="Center" Text="A" />
                    <TextBlock VerticalAlignment="Center" Text="ABB" />
                </ikw:SimpleStackPanel>

                <ikw:SimpleStackPanel
                    x:Name="RightOrBottomStackPanel"
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="2"
                    Background="Transparent"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock VerticalAlignment="Center" Text="EFFF" />
                    <TextBlock VerticalAlignment="Center" Text="G" />
                </ikw:SimpleStackPanel>
            </Grid>

            <ikw:SimpleStackPanel
                x:Name="CenterStackPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Transparent"
                Orientation="Horizontal"
                Spacing="8">
                <TextBlock VerticalAlignment="Center" Text="C" />
                <TextBlock VerticalAlignment="Center" Text="D" />
            </ikw:SimpleStackPanel>
        </Grid>
    </Grid>
</Window>