<ui:Page
    x:Class="Flow.Bar.Views.SettingPages.SettingsPaneAbout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Flow.Bar.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingsVm="clr-namespace:Flow.Bar.ViewModels.SettingPages"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="{DynamicResource SettingWindow_About}"
    Margin="{StaticResource DefaultPageMargin}"
    d:DataContext="{d:DesignInstance Type=settingsVm:SettingsPaneAboutViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ui:ScrollViewerEx
        x:Name="RootPageScrollViewer"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <ikw:SimpleStackPanel Orientation="Vertical" Spacing="{StaticResource SettingsCardSpacing}">
            <TextBlock Style="{StaticResource SettingsFirstSectionHeaderTextBlockStyle}" Text="App" />
            <controls:SettingsCardEx Description="{DynamicResource SettingPaneAbout_Version}" Header="{Binding Version}">
                <controls:SettingsCardEx.HeaderIcon>
                    <ui:FontIcon Glyph="&#xe946;" />
                </controls:SettingsCardEx.HeaderIcon>
            </controls:SettingsCardEx>

            <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Related" />
            <controls:SettingsCardEx Header="Click to support">
                <controls:SettingsCardEx.HeaderIcon>
                    <ui:FontIcon Glyph="&#xe946;" />
                </controls:SettingsCardEx.HeaderIcon>
            </controls:SettingsCardEx>
        </ikw:SimpleStackPanel>
    </ui:ScrollViewerEx>
</ui:Page>