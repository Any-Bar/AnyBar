<ui:Page
    x:Class="Flow.Bar.Views.SettingPages.SettingsPaneAbout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingsVm="clr-namespace:Flow.Bar.ViewModels.SettingPages"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="{DynamicResource SettingWindow.About}"
    d:DataContext="{d:DesignInstance Type=settingsVm:SettingsPaneAboutViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ikw:SimpleStackPanel Orientation="Vertical" Spacing="{StaticResource SettingsCardSpacing}">
        <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="App" />
        <ui:SettingsCard Description="{DynamicResource SettingPaneAbout.Version}" Header="{Binding Version}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xe946;" />
            </ui:SettingsCard.HeaderIcon>
        </ui:SettingsCard>

        <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Related" />
        <ui:SettingsCard Header="Click to support">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xe946;" />
            </ui:SettingsCard.HeaderIcon>
        </ui:SettingsCard>
    </ikw:SimpleStackPanel>
</ui:Page>