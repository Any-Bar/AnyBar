<ui:Page
    x:Class="Flow.Bar.Views.SettingPages.SettingsPaneBarElementSetting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Flow.Bar.Controls"
    xmlns:converters="clr-namespace:Flow.Bar.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="clr-namespace:Flow.Bar.Models.Enums"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Flow.Bar.Models.AppBar"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewModels="clr-namespace:Flow.Bar.ViewModels.SettingPages"
    Title="{DynamicResource SettingWindow_AppBar}"
    d:DataContext="{d:DesignInstance viewModels:SettingsPaneBarElementSettingViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ui:ScrollViewerEx
        x:Name="RootPageScrollViewer"
        Padding="{StaticResource PageRootScrollViewerPadding}"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <ikw:SimpleStackPanel Orientation="Vertical" Spacing="{StaticResource SettingsCardSpacing}">
            <controls:SettingsCardEx x:Name="AddBarElementCard" Header="{DynamicResource SettingPaneBarElementSetting_AddBarElementHeader}">
                <Button
                    x:Name="AddBarElementButton"
                    Command="{Binding AddBarElementCommand, Mode=OneTime}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Self}}"
                    Content="{DynamicResource SettingPaneBarElementSetting_AddBarElement}"
                    IsEnabled="{Binding IsInitialized, Mode=OneWay}"
                    Style="{DynamicResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}" />
            </controls:SettingsCardEx>

            <ikw:SimpleStackPanel
                Margin="{StaticResource SettingsSectionHeaderMargin}"
                Orientation="Horizontal"
                Spacing="{StaticResource SettingsElementsSpacing}">
                <ui:FontIcon
                    VerticalAlignment="Center"
                    FontSize="{StaticResource BodyFontIconFontSize}"
                    Foreground="{StaticResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}"
                    Glyph="&#xE8CB;" />
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{StaticResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}"
                    Text="{DynamicResource SettingPanePlugins_SortBy}" />
                <ComboBox
                    VerticalAlignment="Center"
                    DisplayMemberPath="Display"
                    ItemsSource="{Binding AllSortModes, Mode=OneTime}"
                    SelectedValue="{Binding SortMode, Mode=TwoWay}"
                    SelectedValuePath="Value" />
            </ikw:SimpleStackPanel>

            <controls:StackView
                x:Name="BarElementStackView"
                Margin="{StaticResource SettingsSectionHeaderMargin}"
                CanReorderItems="True"
                DropScrollViewer="{Binding RootPageScrollViewer, Mode=OneTime}"
                IsHoverEnabled="False"
                ItemsSource="{Binding BarElements, Mode=OneTime}"
                Orientation="Vertical"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <controls:StackView.Style>
                    <Style BasedOn="{StaticResource DefaultStackViewStyle}" TargetType="controls:StackView">
                        <Setter Property="CanReorderItems" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SortMode}" Value="{x:Static enums:SettingsPaneBarElementSettingSortMode.LeftTopToRightBottom}">
                                <Setter Property="CanReorderItems" Value="True" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SortMode}" Value="{x:Static enums:SettingsPaneBarElementSettingSortMode.RightBottomToLeftTop}">
                                <Setter Property="CanReorderItems" Value="True" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Items.Count}" Value="0">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <TextBlock
                                                x:Name="NoBarElementsYetTextBlock"
                                                Width="{StaticResource ListViewEmptyTextWidth}"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource {x:Static ui:ThemeKeys.BodyTextBlockStyleKey}}"
                                                Text="{DynamicResource SettingPaneBarElementSetting_NoBarElementsYet}"
                                                TextWrapping="Wrap" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:StackView.Style>
                <controls:StackView.ItemTemplate>
                    <DataTemplate DataType="models:BarElementViewModel">
                        <controls:SettingsCardEx x:Name="BarElementSettingsCard">
                            <controls:SettingsCardEx.Header>
                                <TextBlock
                                    Text="{Binding Name, Mode=OneTime}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Disabled, Mode=OneTime}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource SettingsCardForegroundDisabled}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </controls:SettingsCardEx.Header>
                            <controls:SettingsCardEx.HeaderIcon>
                                <Image
                                    Width="16"
                                    Height="16"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="{Binding Image, Mode=OneWay}" />
                            </controls:SettingsCardEx.HeaderIcon>

                            <controls:FontIconButton
                                x:Name="MoreOptionsButton"
                                Width="28"
                                Height="35"
                                Click="MoreOptionsButton_Click"
                                Tag="{Binding ., Mode=OneTime}"
                                ToolTip="{DynamicResource SettingPanePlugins_MoreOptions}">
                                <ui:FontIcon Glyph="&#xE712;" />
                            </controls:FontIconButton>
                        </controls:SettingsCardEx>
                    </DataTemplate>
                </controls:StackView.ItemTemplate>
            </controls:StackView>
        </ikw:SimpleStackPanel>
    </ui:ScrollViewerEx>
</ui:Page>