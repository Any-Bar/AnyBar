<ui:Page
    x:Class="Flow.Bar.Views.SettingsPaneAppBarSetting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Flow.Bar.Controls"
    xmlns:converters="clr-namespace:Flow.Bar.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enum="clr-namespace:Flow.Bar.Enums"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Flow.Bar.Models.AppBar"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:Flow.Bar.ViewModels"
    Title="{DynamicResource SettingWindow_AppBar}"
    d:DataContext="{d:DesignInstance viewmodels:SettingsPaneAppBarSettingViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ui:Page.Resources>
        <converters:DockModeToImageSourceConverter x:Key="DockModeToImageSourceConverter" />
        <converters:DockModeToStringConverter x:Key="DockModeToStringConverter" />
    </ui:Page.Resources>

    <ui:ScrollViewerEx
        x:Name="RootPageScrollViewer"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <ikw:SimpleStackPanel
            x:Name="AppBarStackPanel"
            Margin="{StaticResource PageScrollViewerContentMargin}"
            Spacing="{StaticResource SettingsCardSpacing}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image
                    Grid.Column="0"
                    Width="100"
                    Height="100"
                    VerticalAlignment="Center"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Source="{Binding DockMode, Converter={StaticResource DockModeToImageSourceConverter}}" />
                <TextBlock
                    Grid.Column="1"
                    Margin="10 0 0 0"
                    VerticalAlignment="Center"
                    Style="{StaticResource {x:Static ui:ThemeKeys.SubtitleTextBlockStyleKey}}"
                    Text="{Binding Name, Mode=OneWay}" />
                <Button
                    Grid.Column="3"
                    MinWidth="135"
                    MinHeight="30"
                    Command="{Binding RemoveAppBarCommand, Mode=OneTime}"
                    Content="{DynamicResource SettingPaneAppBarSetting_Remove}" />
            </Grid>

            <ui:SettingsCard
                x:Name="BarNameCard"
                Margin="{StaticResource SettingsSectionHeaderMargin}"
                Header="{DynamicResource SettingPaneAppBarSetting_Name}">
                <TextBox MinWidth="120" Text="{Binding Name, Mode=TwoWay}" />
            </ui:SettingsCard>

            <TextBlock
                x:Name="BarBehaviourTitle"
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="{DynamicResource SettingPaneAppBarSetting_BarBehaviour}" />
            <ui:SettingsCard Header="{DynamicResource SettingPaneAppBarSetting_DockMode}">
                <ComboBox
                    DisplayMemberPath="Display"
                    ItemsSource="{Binding AllDockModes, Mode=OneTime}"
                    SelectedValue="{Binding DockMode, Mode=TwoWay}"
                    SelectedValuePath="Value" />
            </ui:SettingsCard>

            <ui:SettingsCard Header="{DynamicResource SettingPaneAppBarSetting_Monitor}">
                <ComboBox
                    DisplayMemberPath="Display"
                    ItemsSource="{Binding AllMonitorNames, Mode=OneTime}"
                    SelectedValue="{Binding MonitorName, Mode=TwoWay}"
                    SelectedValuePath="Value" />
            </ui:SettingsCard>

            <ui:SettingsCard Header="{Binding DockMode, Converter={StaticResource DockModeToStringConverter}, ConverterParameter={x:Static enum:DockModeToStringType.FollowSystemTaskbarWidthOrHeight}}">
                <controls:ToggleSwitchEx IsOn="{Binding FollowSystemTaskbarWidthOrHeight, Mode=TwoWay}" />
            </ui:SettingsCard>

            <ui:SettingsCard Header="{Binding DockMode, Converter={StaticResource DockModeToStringConverter}, ConverterParameter={x:Static enum:DockModeToStringType.DockedWidthOrHeight}}">
                <ui:NumberBox
                    MinWidth="120"
                    LargeChange="10"
                    Maximum="{Binding MaxDockedWidthOrHeight, Mode=OneWay}"
                    Minimum="{Binding MinDockedWidthOrHeight, Mode=OneWay}"
                    SmallChange="5"
                    SpinButtonPlacementMode="Compact"
                    Value="{Binding DockedWidthOrHeight, Mode=TwoWay}" />
            </ui:SettingsCard>

            <ui:SettingsCard Header="{DynamicResource SettingPaneAppBarSetting_Resizable}">
                <controls:ToggleSwitchEx IsOn="{Binding IsResizable, Mode=TwoWay}" />
            </ui:SettingsCard>

            <TextBlock
                x:Name="BarElementsTitle"
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="{DynamicResource SettingPaneAppBarSetting_BarElements}" />
            <ui:SettingsCard
                x:Name="LeftOrTopBarElementsCard"
                Command="{Binding OpenBarElementSettingCommand, Mode=OneTime}"
                CommandParameter="{x:Static enum:BarElementModelPosition.LeftOrTop}"
                Header="{Binding DockMode, Converter={StaticResource DockModeToStringConverter}, ConverterParameter={x:Static enum:DockModeToStringType.LeftOrTopBarElements}}"
                IsClickEnabled="True"
                Tag="{Binding AppBarModel, Mode=OneWay}">

                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE71D;" />
                </ui:SettingsCard.HeaderIcon>

                <ui:SettingsCard.ActionIcon>
                    <ui:FontIcon Glyph="&#xE76C;" />
                </ui:SettingsCard.ActionIcon>
            </ui:SettingsCard>

            <ui:SettingsCard
                x:Name="CenterBarElementsCard"
                Command="{Binding OpenBarElementSettingCommand, Mode=OneTime}"
                CommandParameter="{x:Static enum:BarElementModelPosition.Center}"
                Header="{DynamicResource SettingPaneAppBarSetting_CenterBarElements}"
                IsClickEnabled="True"
                Tag="{Binding AppBarModel, Mode=OneWay}">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE71D;" />
                </ui:SettingsCard.HeaderIcon>

                <ui:SettingsCard.ActionIcon>
                    <ui:FontIcon Glyph="&#xE76C;" />
                </ui:SettingsCard.ActionIcon>
            </ui:SettingsCard>

            <ui:SettingsCard
                x:Name="RightOrBottomBarElementsCard"
                Command="{Binding OpenBarElementSettingCommand, Mode=OneTime}"
                CommandParameter="{x:Static enum:BarElementModelPosition.RightOrBottom}"
                Header="{Binding DockMode, Converter={StaticResource DockModeToStringConverter}, ConverterParameter={x:Static enum:DockModeToStringType.RightOrBottomBarElements}}"
                IsClickEnabled="True"
                Tag="{Binding AppBarModel, Mode=OneWay}">

                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE71D;" />
                </ui:SettingsCard.HeaderIcon>

                <ui:SettingsCard.ActionIcon>
                    <ui:FontIcon Glyph="&#xE76C;" />
                </ui:SettingsCard.ActionIcon>
            </ui:SettingsCard>
        </ikw:SimpleStackPanel>
    </ui:ScrollViewerEx>
</ui:Page>