<ui:Page
    x:Class="Flow.Bar.Views.SettingPages.SettingsPaneAppBarSetting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enum="clr-namespace:Flow.Bar.Models.Enums"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Flow.Bar.Models.AppBar"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:tscontrol="clr-namespace:Flow.Bar.Controls.ToggleSwitch"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewModels="clr-namespace:Flow.Bar.ViewModels.SettingPages"
    Title="{DynamicResource SettingWindow_AppBar}"
    d:DataContext="{d:DesignInstance viewModels:SettingsPaneAppBarSettingViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ikw:SimpleStackPanel x:Name="AppBarStackPanel" Spacing="{StaticResource SettingsCardSpacing}">
        <TextBlock
            x:Name="BarBehaviourTitle"
            Style="{StaticResource SettingsFirstSectionHeaderTextBlockStyle}"
            Text="{DynamicResource SettingPaneAppBarSetting_BarBehaviour}" />
        <ui:SettingsCard Header="{DynamicResource SettingPaneAppBarSetting_DockMode}">
            <ComboBox
                DisplayMemberPath="Display"
                ItemsSource="{Binding AllDockModes, Mode=OneTime}"
                SelectedValue="{Binding DockMode, Mode=TwoWay}"
                SelectedValuePath="Value" />
        </ui:SettingsCard>

        <ui:SettingsCard Header="{DynamicResource SettingPaneAppBarSetting_Monitor}">
            <ComboBox
                DisplayMemberPath="Display"
                ItemsSource="{Binding AllMonitorNames, Mode=OneTime}"
                SelectedValue="{Binding MonitorName, Mode=TwoWay}"
                SelectedValuePath="Value" />
        </ui:SettingsCard>

        <ui:SettingsCard Header="{DynamicResource SettingPaneAppBarSetting_Resizable}">
            <tscontrol:ToggleSwitchEx IsOn="{Binding IsResizable, Mode=TwoWay}" />
        </ui:SettingsCard>

        <TextBlock
            x:Name="BarElementsTitle"
            Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
            Text="{DynamicResource SettingPaneAppBarSetting_BarElements}" />
        <ui:SettingsCard
            x:Name="LeftOrTopBarElementsCard"
            IsClickEnabled="True"
            Tag="{Binding AppBarModel, Mode=OneWay}">
            <ui:SettingsCard.Style>
                <Style TargetType="ui:SettingsCard">
                    <Setter Property="Header" Value="{DynamicResource SettingPaneAppBarSetting_LeftBarElements}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Left}">
                            <Setter Property="Header" Value="{DynamicResource SettingPaneAppBarSetting_TopBarElements}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Right}">
                            <Setter Property="Header" Value="{DynamicResource SettingPaneAppBarSetting_TopBarElements}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ui:SettingsCard.Style>

            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xE71D;" />
            </ui:SettingsCard.HeaderIcon>

            <ui:SettingsCard.ActionIcon>
                <ui:FontIcon Glyph="&#xE76C;" />
            </ui:SettingsCard.ActionIcon>
        </ui:SettingsCard>

        <ui:SettingsCard
            x:Name="CenterBarElementsCard"
            Header="{DynamicResource SettingPaneAppBarSetting_CenterBarElements}"
            IsClickEnabled="True"
            Tag="{Binding AppBarModel, Mode=OneWay}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xE71D;" />
            </ui:SettingsCard.HeaderIcon>

            <ui:SettingsCard.ActionIcon>
                <ui:FontIcon Glyph="&#xE76C;" />
            </ui:SettingsCard.ActionIcon>
        </ui:SettingsCard>

        <ui:SettingsCard
            x:Name="RightOrBottomBarElementsCard"
            IsClickEnabled="True"
            Tag="{Binding AppBarModel, Mode=OneWay}">
            <ui:SettingsCard.Style>
                <Style TargetType="ui:SettingsCard">
                    <Setter Property="Header" Value="{DynamicResource SettingPaneAppBarSetting_RightBarElements}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Left}">
                            <Setter Property="Header" Value="{DynamicResource SettingPaneAppBarSetting_BottomBarElements}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DockMode}" Value="{x:Static enum:AppBarDockMode.Right}">
                            <Setter Property="Header" Value="{DynamicResource SettingPaneAppBarSetting_BottomBarElements}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ui:SettingsCard.Style>

            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xE71D;" />
            </ui:SettingsCard.HeaderIcon>

            <ui:SettingsCard.ActionIcon>
                <ui:FontIcon Glyph="&#xE76C;" />
            </ui:SettingsCard.ActionIcon>
        </ui:SettingsCard>
    </ikw:SimpleStackPanel>
</ui:Page>