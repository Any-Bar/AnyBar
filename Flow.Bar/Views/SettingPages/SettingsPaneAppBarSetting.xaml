<ui:Page
    x:Class="Flow.Bar.Views.SettingPages.SettingsPaneAppBarSetting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Flow.Bar.Models.AppBar"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewModels="clr-namespace:Flow.Bar.ViewModels.SettingPages"
    Title="{DynamicResource SettingWindow_AppBar}"
    d:DataContext="{d:DesignInstance viewModels:SettingsPaneAppBarSettingViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <ikw:SimpleStackPanel x:Name="AppBarStackPanel" Spacing="{StaticResource SettingsCardSpacing}">
            <ui:SettingsCard Header="{DynamicResource SettingPaneAppBar_DockMode}">
                <ComboBox
                    DisplayMemberPath="Display"
                    ItemsSource="{Binding AllDockModes, Mode=OneTime}"
                    SelectedValue="{Binding DockMode, Mode=TwoWay}"
                    SelectedValuePath="Value" />
            </ui:SettingsCard>

            <ui:SettingsCard Header="{DynamicResource SettingPaneAppBar_Monitor}">
                <ComboBox
                    DisplayMemberPath="Display"
                    ItemsSource="{Binding AllMonitorNames, Mode=OneTime}"
                    SelectedValue="{Binding MonitorName, Mode=TwoWay}"
                    SelectedValuePath="Value" />
            </ui:SettingsCard>

            <ui:SettingsCard Header="{DynamicResource SettingPaneAppBar_Resizable}">
                <ui:ToggleSwitch IsOn="{Binding IsResizable, Mode=TwoWay}" />
            </ui:SettingsCard>

            <ui:SettingsExpander Header="{DynamicResource SettingPaneAppBar_BarElements}" />
        </ikw:SimpleStackPanel>
    </Grid>
</ui:Page>