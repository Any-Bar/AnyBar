<ui:Page
    x:Class="Flow.Bar.Views.SettingPages.SettingsPaneAppBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Flow.Bar.Models.AppBar"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewModels="clr-namespace:Flow.Bar.ViewModels.SettingPages"
    Title="{DynamicResource SettingWindow_AppBar}"
    d:DataContext="{d:DesignInstance viewModels:SettingsPaneAppBarViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <ui:ItemsRepeater
            x:Name="AppBarListView"
            ItemsSource="{Binding AppBars}"
            Visibility="Visible">
            <ui:ItemsRepeater.ItemTemplate>
                <DataTemplate DataType="models:AppBarModel">
                    <ui:SettingsCard
                        Click="AppBarSettingsCard_Click"
                        Header="{DynamicResource SettingWindow_AppBar}"
                        IsClickEnabled="True"
                        Tag="{Binding}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Glyph="&#xE90E;" />
                        </ui:SettingsCard.HeaderIcon>

                        <ui:SettingsCard.ActionIcon>
                            <ui:FontIcon Glyph="&#xE76C;" />
                        </ui:SettingsCard.ActionIcon>

                        <ui:ToggleSwitch
                            IsOn="{Binding IsEnabled, Mode=TwoWay}"
                            Tag="{Binding}"
                            Toggled="AppBarToggleSwitch_Toggled" />
                    </ui:SettingsCard>
                </DataTemplate>
            </ui:ItemsRepeater.ItemTemplate>
        </ui:ItemsRepeater>

        <ikw:SimpleStackPanel
            x:Name="NoAppBarStackPanel"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="{StaticResource SettingsCardSpacing}"
            Visibility="Collapsed">
            <TextBlock Text="There are no appbars yet. Add one appbar to start!" />
            <Button
                HorizontalAlignment="Center"
                Command="{Binding AddAppBarCommand}"
                Content="Add AppBar" />
        </ikw:SimpleStackPanel>
    </Grid>
</ui:Page>