<ui:Page
    x:Class="Flow.Bar.Views.SettingPages.SettingsPaneAppBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:lvcontrol="clr-namespace:Flow.Bar.Controls.ListView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Flow.Bar.Models.AppBar"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:tscontrol="clr-namespace:Flow.Bar.Controls.ToggleSwitch"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewModels="clr-namespace:Flow.Bar.ViewModels.SettingPages"
    Title="{DynamicResource SettingWindow_AppBar}"
    d:DataContext="{d:DesignInstance viewModels:SettingsPaneAppBarViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ikw:SimpleStackPanel Orientation="Vertical" Spacing="{StaticResource SettingsCardSpacing}">
        <ui:SettingsCard x:Name="AddAppBarCard" Header="{DynamicResource SettingPaneAppBar_AddAppBarHeader}">
            <Button
                x:Name="AddAppBarButton"
                Command="{Binding AddAppBarCommand, Mode=OneTime}"
                Content="{DynamicResource SettingPaneAppBar_AddAppBar}"
                Style="{DynamicResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}" />
        </ui:SettingsCard>
        <lvcontrol:ListViewEx x:Name="AppBarListView" ItemsSource="{Binding AppBars}">
            <lvcontrol:ListViewEx.ItemTemplate>
                <DataTemplate DataType="models:AppBarModel">
                    <ui:SettingsCard
                        x:Name="AppBarSettingsCard"
                        Click="AppBarSettingsCard_Click"
                        Header="{DynamicResource SettingWindow_AppBar}"
                        IsClickEnabled="True"
                        Tag="{Binding}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Glyph="&#xE90E;" />
                        </ui:SettingsCard.HeaderIcon>

                        <ui:SettingsCard.ActionIcon>
                            <ui:FontIcon Glyph="&#xE76C;" />
                        </ui:SettingsCard.ActionIcon>

                        <tscontrol:ToggleSwitchEx
                            IsOn="{Binding IsEnabled, Mode=TwoWay}"
                            Tag="{Binding}"
                            Toggled="AppBarToggleSwitch_Toggled" />
                    </ui:SettingsCard>
                </DataTemplate>
            </lvcontrol:ListViewEx.ItemTemplate>
        </lvcontrol:ListViewEx>
    </ikw:SimpleStackPanel>
</ui:Page>