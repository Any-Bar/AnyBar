<ui:Page
    x:Class="Flow.Bar.Views.SettingPages.SettingsPaneAppBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Flow.Bar.Controls"
    xmlns:converters="clr-namespace:Flow.Bar.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="clr-namespace:Flow.Bar.Models.Enums"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Flow.Bar.Models.AppBar"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewModels="clr-namespace:Flow.Bar.ViewModels.SettingPages"
    Title="{DynamicResource SettingWindow_AppBar}"
    d:DataContext="{d:DesignInstance viewModels:SettingsPaneAppBarViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ui:Page.Resources>
        <converters:DockModeToImageSourceConverter x:Key="DockModeToImageSourceConverter" />
    </ui:Page.Resources>

    <ui:ScrollViewerEx
        x:Name="RootPageScrollViewer"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <ikw:SimpleStackPanel
            Margin="{StaticResource PageScrollViewerContentMargin}"
            Orientation="Vertical"
            Spacing="{StaticResource SettingsCardSpacing}">
            <controls:SettingsCardEx x:Name="AddAppBarCard" Header="{DynamicResource SettingPaneAppBar_AddAppBarHeader}">
                <Button
                    x:Name="AddAppBarButton"
                    Command="{Binding AddAppBarCommand, Mode=OneTime}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Self}}"
                    Content="{DynamicResource SettingPaneAppBar_AddAppBar}"
                    IsEnabled="{Binding IsInitialized, Mode=OneWay}"
                    Style="{DynamicResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}" />
            </controls:SettingsCardEx>

            <ikw:SimpleStackPanel
                Margin="{StaticResource SettingsSectionHeaderMargin}"
                Orientation="Horizontal"
                Spacing="{StaticResource SettingsElementsSpacing}">
                <ui:FontIcon
                    VerticalAlignment="Center"
                    FontSize="{StaticResource BodyFontIconFontSize}"
                    Foreground="{StaticResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}"
                    Glyph="&#xE8CB;" />
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{StaticResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}"
                    Text="{DynamicResource SettingPanePlugins_SortBy}" />
                <ComboBox
                    VerticalAlignment="Center"
                    DisplayMemberPath="Display"
                    ItemsSource="{Binding AllSortModes, Mode=OneTime}"
                    SelectedValue="{Binding SortMode, Mode=TwoWay}"
                    SelectedValuePath="Value" />
            </ikw:SimpleStackPanel>

            <controls:ListViewEx
                x:Name="AppBarStackView"
                Margin="{StaticResource SettingsSectionHeaderMargin}"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Center"
                DropScrollViewer="{Binding ElementName=RootPageScrollViewer, Mode=OneTime}"
                IsHoverEnabled="False"
                IsSelectionEnabled="False"
                ItemIsTabStop="False"
                ItemsSource="{Binding AppBars, Mode=OneTime}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <controls:ListViewEx.Style>
                    <Style BasedOn="{StaticResource DefaultListViewStyle}" TargetType="controls:ListViewEx">
                        <Setter Property="CanReorderItems" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SortMode}" Value="{x:Static enums:SettingsPaneAppBarSortMode.Order}">
                                <Setter Property="CanReorderItems" Value="True" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Items.Count}" Value="0">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <TextBlock
                                                x:Name="NoAppBarsYetTextBlock"
                                                Width="{StaticResource ListViewEmptyTextWidth}"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource {x:Static ui:ThemeKeys.BodyTextBlockStyleKey}}"
                                                Text="{DynamicResource SettingPaneAppBar_NoAppBarsYet}"
                                                TextWrapping="Wrap" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:ListViewEx.Style>
                <controls:ListViewEx.ItemTemplate>
                    <DataTemplate DataType="models:AppBarModel">
                        <controls:SettingsCardEx
                            x:Name="AppBarSettingsCard"
                            Command="{Binding DataContext.OpenAppBarSettingCommand, RelativeSource={RelativeSource AncestorType=controls:ListViewEx}, Mode=OneTime}"
                            CommandParameter="{Binding ., Mode=OneTime}"
                            Header="{Binding Name, Mode=OneWay}"
                            IsClickEnabled="True"
                            Tag="{Binding ., Mode=OneTime}">
                            <controls:SettingsCardEx.HeaderIcon>
                                <Image
                                    Width="16"
                                    Height="16"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="{Binding DockMode, Converter={StaticResource DockModeToImageSourceConverter}}" />
                            </controls:SettingsCardEx.HeaderIcon>

                            <controls:SettingsCardEx.ActionIcon>
                                <ui:FontIcon Glyph="&#xE76C;" />
                            </controls:SettingsCardEx.ActionIcon>

                            <controls:ToggleSwitchEx
                                IsOn="{Binding IsEnabled, Mode=TwoWay}"
                                Tag="{Binding ., Mode=OneTime}"
                                Toggled="AppBarToggleSwitch_Toggled" />
                        </controls:SettingsCardEx>
                    </DataTemplate>
                </controls:ListViewEx.ItemTemplate>
            </controls:ListViewEx>
        </ikw:SimpleStackPanel>
    </ui:ScrollViewerEx>
</ui:Page>