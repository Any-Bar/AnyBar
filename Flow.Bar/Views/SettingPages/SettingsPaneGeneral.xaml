<ui:Page
    x:Class="Flow.Bar.Views.SettingPages.SettingsPaneGeneral"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Flow.Bar.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingsVm="clr-namespace:Flow.Bar.ViewModels.SettingPages"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="{DynamicResource SettingWindow_General}"
    d:DataContext="{d:DesignInstance Type=settingsVm:SettingsPaneGeneralViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ui:ScrollViewerEx
        x:Name="RootFrameScrollViewer"
        Padding="{StaticResource PageRootScrollViewerPadding}"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <ikw:SimpleStackPanel Orientation="Vertical" Spacing="{StaticResource SettingsCardSpacing}">
            <TextBlock
                x:Name="LanguageTitle"
                Style="{StaticResource SettingsFirstSectionHeaderTextBlockStyle}"
                Text="{DynamicResource SettingPaneGeneral_Language}" />
            <controls:SettingsCardEx
                x:Name="LanguageCard"
                Description="{DynamicResource SettingPaneGeneral_AppDisplayLanguage}"
                Header="{DynamicResource SettingPaneGeneral_Language}">
                <controls:SettingsCardEx.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE8C1;" />
                </controls:SettingsCardEx.HeaderIcon>

                <ComboBox
                    DisplayMemberPath="Display"
                    ItemsSource="{Binding Languages, Mode=OneTime}"
                    SelectedValue="{Binding Language, Mode=TwoWay}"
                    SelectedValuePath="LanguageCode" />
            </controls:SettingsCardEx>

            <TextBlock
                x:Name="BehaviourTitle"
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="{DynamicResource SettingPaneGeneral_Behaviour}" />
            <controls:SettingsCardEx
                x:Name="HideSettingWindowCard"
                Description="{DynamicResource SettingPaneGeneral_HideSettingWindowDescription}"
                Header="{DynamicResource SettingPaneGeneral_HideSettingWindow}">
                <controls:SettingsCardEx.HeaderIcon>
                    <ui:FontIcon Glyph="&#xed1a;" />
                </controls:SettingsCardEx.HeaderIcon>

                <controls:ToggleSwitchEx IsOn="{Binding Settings.HideSettingWindow, Mode=TwoWay}" />
            </controls:SettingsCardEx>

            <TextBlock
                x:Name="AppearanceTitle"
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="{DynamicResource SettingPaneGeneral_Appearance}" />
            <controls:SettingsCardEx
                x:Name="TransparencyEffectsCard"
                Description="{DynamicResource SettingPaneGeneral_TransparencyEffectsDescription}"
                Header="{DynamicResource SettingPaneGeneral_TransparencyEffects}">
                <controls:SettingsCardEx.HeaderIcon>
                    <ui:FontIcon Glyph="&#xF4A5;" />
                </controls:SettingsCardEx.HeaderIcon>

                <controls:ToggleSwitchEx IsOn="{Binding Settings.EnableTransparencyEffects, Mode=TwoWay}" />
            </controls:SettingsCardEx>
            <controls:SettingsCardEx
                x:Name="AnimationEffectsCard"
                Description="{DynamicResource SettingPaneGeneral_AnimationEffectsDescription}"
                Header="{DynamicResource SettingPaneGeneral_AnimationEffects}">
                <controls:SettingsCardEx.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE805;" />
                </controls:SettingsCardEx.HeaderIcon>

                <controls:ToggleSwitchEx IsOn="{Binding Settings.EnableAnimationEffects, Mode=TwoWay}" />
            </controls:SettingsCardEx>
        </ikw:SimpleStackPanel>
    </ui:ScrollViewerEx>
</ui:Page>