<ui:Page
    x:Class="Flow.Bar.Views.SettingsPaneGeneral"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Flow.Bar.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:Flow.Bar.ViewModels"
    Title="{DynamicResource SettingWindow_General}"
    d:DataContext="{d:DesignInstance Type=viewmodels:SettingsPaneGeneralViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ui:ScrollViewerEx
        x:Name="RootPageScrollViewer"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <ikw:SimpleStackPanel
            Margin="{StaticResource PageScrollViewerContentMargin}"
            Orientation="Vertical"
            Spacing="{StaticResource SettingsCardSpacing}">
            <TextBlock
                x:Name="LanguageTitle"
                Style="{StaticResource SettingsFirstSectionHeaderTextBlockStyle}"
                Text="{DynamicResource SettingPaneGeneral_Language}" />
            <controls:SettingsCardEx
                x:Name="LanguageCard"
                Description="{DynamicResource SettingPaneGeneral_AppDisplayLanguage}"
                Header="{DynamicResource SettingPaneGeneral_Language}">
                <controls:SettingsCardEx.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE8C1;" />
                </controls:SettingsCardEx.HeaderIcon>

                <ComboBox
                    DisplayMemberPath="Display"
                    ItemsSource="{Binding Languages, Mode=OneTime}"
                    SelectedValue="{Binding Language, Mode=TwoWay}"
                    SelectedValuePath="LanguageCode" />
            </controls:SettingsCardEx>

            <TextBlock
                x:Name="BehaviourTitle"
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="{DynamicResource SettingPaneGeneral_Behaviour}" />
            <controls:SettingsExpanderEx
                x:Name="StartOnSystemStartupCard"
                Description="{DynamicResource SettingPaneGeneral_StartOnSystemStartupDescription}"
                Header="{DynamicResource SettingPaneGeneral_StartOnSystemStartup}">
                <controls:SettingsExpanderEx.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE7B5;" />
                </controls:SettingsExpanderEx.HeaderIcon>

                <controls:ToggleSwitchEx IsOn="{Binding StartOnSystemStartup, Mode=TwoWay}" />

                <controls:SettingsExpanderEx.Items>
                    <controls:SettingsCardEx
                        x:Name="UseLogonTaskForStartupCard"
                        Description="{DynamicResource SettingPaneGeneral_UseLogonTaskForStartupDescription}"
                        Header="{DynamicResource SettingPaneGeneral_UseLogonTaskForStartup}">
                        <controls:SettingsCardEx.HeaderIcon>
                            <ui:FontIcon Glyph="&#xE823;" />
                        </controls:SettingsCardEx.HeaderIcon>

                        <controls:ToggleSwitchEx IsOn="{Binding UseLogonTaskForStartup, Mode=TwoWay}" />
                    </controls:SettingsCardEx>
                </controls:SettingsExpanderEx.Items>
            </controls:SettingsExpanderEx>
            <controls:SettingsCardEx
                x:Name="AlwaysRunAsAdministratorCard"
                Description="{DynamicResource SettingPaneGeneral_AlwaysRunAsAdministratorDescription}"
                Header="{DynamicResource SettingPaneGeneral_AlwaysRunAsAdministrator}">
                <controls:SettingsCardEx.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE7EF;" />
                </controls:SettingsCardEx.HeaderIcon>

                <controls:ToggleSwitchEx IsOn="{Binding AlwaysRunAsAdministrator, Mode=TwoWay}" />
            </controls:SettingsCardEx>
            <controls:SettingsCardEx
                x:Name="HideSettingWindowCard"
                Description="{DynamicResource SettingPaneGeneral_HideSettingWindowDescription}"
                Header="{DynamicResource SettingPaneGeneral_HideSettingWindow}">
                <controls:SettingsCardEx.HeaderIcon>
                    <ui:FontIcon Glyph="&#xed1a;" />
                </controls:SettingsCardEx.HeaderIcon>

                <controls:ToggleSwitchEx IsOn="{Binding Settings.HideSettingWindow, Mode=TwoWay}" />
            </controls:SettingsCardEx>

            <TextBlock
                x:Name="AppearanceTitle"
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="{DynamicResource SettingPaneGeneral_Appearance}" />
        </ikw:SimpleStackPanel>
    </ui:ScrollViewerEx>
</ui:Page>