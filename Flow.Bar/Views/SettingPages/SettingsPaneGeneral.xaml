<ui:Page
    x:Class="Flow.Bar.Views.SettingPages.SettingsPaneGeneral"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingsVm="clr-namespace:Flow.Bar.ViewModels.SettingPages"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="{DynamicResource SettingWindow.General}"
    d:DataContext="{d:DesignInstance Type=settingsVm:SettingsPaneGeneralViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ikw:SimpleStackPanel Orientation="Vertical" Spacing="{StaticResource SettingsCardSpacing}">
        <TextBlock
            x:Name="LanguageTitle"
            Style="{StaticResource SettingsFirstSectionHeaderTextBlockStyle}"
            Text="{DynamicResource SettingPaneGeneral.Language}" />
        <ui:SettingsCard
            x:Name="LanguageCard"
            Description="{DynamicResource SettingPaneGeneral.AppDisplayLanguage}"
            Header="{DynamicResource SettingPaneGeneral.Language}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xE8C1;" />
            </ui:SettingsCard.HeaderIcon>

            <ComboBox
                DisplayMemberPath="Display"
                ItemsSource="{Binding Languages}"
                SelectedValue="{Binding Language}"
                SelectedValuePath="LanguageCode" />
        </ui:SettingsCard>

        <TextBlock
            x:Name="BehaviourTitle"
            Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
            Text="{DynamicResource SettingPaneGeneral.Behaviour}" />
        <ui:SettingsCard
            x:Name="HideSettingWindowCard"
            Description="{DynamicResource SettingPaneGeneral.HideSettingWindowDescription}"
            Header="{DynamicResource SettingPaneGeneral.HideSettingWindow}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xed1a;" />
            </ui:SettingsCard.HeaderIcon>

            <ui:ToggleSwitch IsOn="{Binding Settings.HideSettingWindow, Mode=TwoWay}" />
        </ui:SettingsCard>

        <TextBlock
            x:Name="AppearanceTitle"
            Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
            Text="{DynamicResource SettingPaneGeneral.Appearance}" />
        <ui:SettingsCard
            x:Name="TransparencyEffectsCard"
            Description="{DynamicResource SettingPaneGeneral.TransparencyEffectsDescription}"
            Header="{DynamicResource SettingPaneGeneral.TransparencyEffects}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xF4A5;" />
            </ui:SettingsCard.HeaderIcon>

            <ui:ToggleSwitch IsOn="{Binding Settings.EnableTransparencyEffects, Mode=TwoWay}" />
        </ui:SettingsCard>
        <ui:SettingsCard
            x:Name="AnimationEffectsCard"
            Description="{DynamicResource SettingPaneGeneral.AnimationEffectsDescription}"
            Header="{DynamicResource SettingPaneGeneral.AnimationEffects}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xE805;" />
            </ui:SettingsCard.HeaderIcon>

            <ui:ToggleSwitch IsOn="{Binding Settings.EnbaleAnimationEffects, Mode=TwoWay}" />
        </ui:SettingsCard>
    </ikw:SimpleStackPanel>
</ui:Page>