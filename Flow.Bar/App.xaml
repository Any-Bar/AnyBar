<Application
    x:Class="Flow.Bar.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Flow.Bar"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    ShutdownMode="OnExplicitShutdown"
    Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  UI Framework  -->
                <ui:ThemeResources />
                <ui:XamlControlsResources />
                <!--  Languages  -->
                <ResourceDictionary Source="/Languages/en.xaml" />
                <!--  Styles  -->
                <ResourceDictionary Source="/Styles/CustomControlTemplate.xaml" />
                <ResourceDictionary Source="/Styles/SettingWindowStyle.xaml" />
                <ResourceDictionary Source="/Styles/ContentDialogStyle.xaml" />
                <ResourceDictionary Source="/Styles/ContextMenuStyle.xaml" />
                <!--  Controls  -->
                <ResourceDictionary Source="/Controls/ContentDialog/ContentDialogEx.xaml" />
                <ResourceDictionary Source="/Controls/MenuFlyout/MenuFlyoutEx.xaml" />
                <ResourceDictionary Source="/Controls/MessageBox/MessageBoxEx.xaml" />
                <ResourceDictionary Source="/Controls/NavigationView/NavigationView.xaml" />
                <ResourceDictionary Source="/Controls/StackView/StackView.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!--  Override styles in UI.Modern.WPF  -->
            <Thickness x:Key="ListViewItemCompactSelectedBorderThemeThickness">2</Thickness>
            <sys:Double x:Key="CheckBoxMinWidth">0</sys:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>