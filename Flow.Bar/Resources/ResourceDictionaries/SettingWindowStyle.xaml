<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--  Spacing between cards  -->
    <sys:Double x:Key="SettingsCardSpacing">4</sys:Double>

    <!--  Style (inc. the correct spacing) of a section header  -->
    <Style
        x:Key="SettingsFirstSectionHeaderTextBlockStyle"
        BasedOn="{StaticResource BodyStrongTextBlockStyle}"
        TargetType="TextBlock">
        <Style.Setters>
            <Setter Property="Margin" Value="1 0 0 4" />
        </Style.Setters>
    </Style>
    <Style
        x:Key="SettingsSectionHeaderTextBlockStyle"
        BasedOn="{StaticResource BodyStrongTextBlockStyle}"
        TargetType="TextBlock">
        <Style.Setters>
            <Setter Property="Margin" Value="1 20 0 4" />
        </Style.Setters>
    </Style>
    <Thickness x:Key="SettingsSectionHeaderMargin">1 20 0 0</Thickness>

    <!--  Spacing between elements  -->
    <sys:Double x:Key="SettingsElementsSpacing">8</sys:Double>

    <!--  Body fontIcon size  -->
    <sys:Double x:Key="BodyFontIconFontSize">12</sys:Double>

    <!--  ListView empty text width  -->
    <sys:Double x:Key="ListViewEmptyTextWidth">300</sys:Double>

</ResourceDictionary>