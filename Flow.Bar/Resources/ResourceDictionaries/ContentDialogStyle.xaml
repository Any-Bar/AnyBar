<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--  Spacing between items  -->
    <sys:Double x:Key="ContentDialogItemSpacing">8</sys:Double>

    <!--  Margin of a content item with the next item  -->
    <Thickness x:Key="ContentDialogContentBottomMargin">0 0 0 20</Thickness>

    <!--  Margin of a content item  -->
    <Thickness x:Key="ContentDialogHeaderContentMargin">24 12 24 12</Thickness>

</ResourceDictionary>