<UserControl
    x:Class="Flow.Bar.Plugin.Network.Views.NetworkControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Flow.Bar.Plugin.Network.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel x:Name="MainPanel" Orientation="Horizontal">
        <StackPanel
            x:Name="UploadPanel"
            Margin="0 0 6 0"
            Orientation="Horizontal">
            <Image
                x:Name="UploadImage"
                Width="16"
                Height="16"
                Margin="0 0 6 0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center" />
            <TextBlock
                x:Name="UploadTextBlock"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="12" />
        </StackPanel>

        <StackPanel x:Name="DownloadPanel" Orientation="Horizontal">
            <Image
                x:Name="DownloadImage"
                Width="16"
                Height="16"
                Margin="0 0 6 0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center" />
            <TextBlock
                x:Name="DownloadTextBlock"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="12" />
        </StackPanel>
    </StackPanel>
</UserControl>