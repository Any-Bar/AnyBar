<Window
    x:Class="AnyBar.Views.SettingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:constants="clr-namespace:AnyBar"
    xmlns:controls="clr-namespace:AnyBar.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="clr-namespace:AnyBar.Enums"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:local="clr-namespace:AnyBar.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:AnyBar.ViewModels"
    Title="{DynamicResource SettingWindow_Title}"
    Width="1026"
    Height="618"
    MinWidth="507"
    MinHeight="327"
    d:DataContext="{d:DesignInstance viewmodels:SettingViewModel}"
    ui:ThemeManager.IsThemeAware="True"
    ui:ThemeManager.RequestedTheme="Default"
    ui:TitleBar.ExtendViewIntoTitleBar="True"
    ui:TitleBar.Height="48"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True"
    Loaded="Window_Loaded"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closed">
            <i:InvokeCommandAction Command="{Binding SaveAppAllSettingsCommand, Mode=OneTime}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <controls:NavigationView
        x:Name="NavigationViewControl"
        AlwaysShowHeader="True"
        Canvas.ZIndex="0"
        ExpandedMinimalModeThresholdWidth="824"
        IsTabStop="False">
        <i:Interaction.Triggers>
            <i:EventTrigger EventName="Loaded">
                <i:InvokeCommandAction Command="{Binding NavigationViewControlLoadedCommand, Mode=OneTime}" CommandParameter="{Binding ElementName=NavigationViewControl}" />
            </i:EventTrigger>
        </i:Interaction.Triggers>
        <controls:NavigationView.Title>
            <Grid
                Margin="{DynamicResource NavigationViewButtonHolderGridMargin}"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch">
                <TextBlock
                    Margin="4 0 0 0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Style="{DynamicResource CaptionTextBlockStyle}"
                    Text="{DynamicResource SettingWindow_Title}" />
            </Grid>
        </controls:NavigationView.Title>

        <controls:NavigationView.PaneCustomContent>
            <ikw:SimpleStackPanel
                Margin="4 10 0 10"
                Orientation="Horizontal"
                Spacing="12">
                <Image
                    Width="60"
                    Height="60"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Source="/Images/app.png" />
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Style="{DynamicResource CaptionTextBlockStyle}"
                    Text="{x:Static constants:Constants.AnyBarFullName}"
                    TextWrapping="NoWrap" />
            </ikw:SimpleStackPanel>
        </controls:NavigationView.PaneCustomContent>

        <controls:NavigationView.MenuItems>
            <controls:NavigationViewItem
                x:Name="GeneralItem"
                Content="{DynamicResource SettingWindow_General}"
                Tag="{x:Static enums:SettingPageTag.General}">
                <controls:NavigationViewItem.Icon>
                    <ui:FontIcon Glyph="&#xE713;" />
                </controls:NavigationViewItem.Icon>
            </controls:NavigationViewItem>
            <controls:NavigationViewItem
                x:Name="AppBarItem"
                Content="{DynamicResource SettingWindow_AppBar}"
                Tag="{x:Static enums:SettingPageTag.AppBar}">
                <controls:NavigationViewItem.Icon>
                    <ui:FontIcon Glyph="&#xE75B;" />
                </controls:NavigationViewItem.Icon>
            </controls:NavigationViewItem>
            <controls:NavigationViewItem
                x:Name="PluginsItem"
                Content="{DynamicResource SettingWindow_Plugins}"
                Tag="{x:Static enums:SettingPageTag.Plugins}">
                <controls:NavigationViewItem.Icon>
                    <ui:FontIcon Glyph="&#xEA86;" />
                </controls:NavigationViewItem.Icon>
            </controls:NavigationViewItem>
            <controls:NavigationViewItem
                x:Name="AboutItem"
                Content="{DynamicResource SettingWindow_About}"
                Tag="{x:Static enums:SettingPageTag.About}">
                <controls:NavigationViewItem.Icon>
                    <ui:FontIcon Glyph="&#xE946;" />
                </controls:NavigationViewItem.Icon>
            </controls:NavigationViewItem>
        </controls:NavigationView.MenuItems>

        <controls:NavigationView.HeaderTemplate>
            <DataTemplate>
                <TextBlock
                    Margin="0 0 0 14"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="{Binding Header, ElementName=NavigationViewControl, Mode=OneWay}" />
            </DataTemplate>
        </controls:NavigationView.HeaderTemplate>

        <ui:Frame x:Name="RootFrame">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="Loaded">
                    <i:InvokeCommandAction Command="{Binding RootFrameLoadedCommand, Mode=OneTime}" CommandParameter="{Binding ElementName=RootFrame}" />
                </i:EventTrigger>
                <i:EventTrigger EventName="Unloaded">
                    <i:InvokeCommandAction Command="{Binding RootFrameUnloadedCommand, Mode=OneTime}" CommandParameter="{Binding ElementName=RootFrame}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </ui:Frame>
    </controls:NavigationView>
</Window>