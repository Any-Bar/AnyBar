<ui:Page
    x:Class="AnyBar.Views.SettingsPaneAppBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:AnyBar.Controls"
    xmlns:converters="clr-namespace:AnyBar.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dragdrop="clr-namespace:AnyBar.Helpers.DragDrop"
    xmlns:enums="clr-namespace:AnyBar.Enums"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:AnyBar.Models.AppBar"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:AnyBar.ViewModels"
    Title="{DynamicResource SettingWindow_AppBar}"
    d:DataContext="{d:DesignInstance viewmodels:SettingsPaneAppBarViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ui:Page.Resources>
        <converters:DockModeToImageSourceConverter x:Key="DockModeToImageSourceConverter" />
        <converters:SettingsPaneAppBarSortModeToCanReorderItemsConverter x:Key="SettingsPaneAppBarSortModeToCanReorderItemsConverter" />
    </ui:Page.Resources>

    <ui:ScrollViewerEx
        x:Name="RootPageScrollViewer"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <ikw:SimpleStackPanel
            Margin="{StaticResource PageScrollViewerContentMargin}"
            Orientation="Vertical"
            Spacing="{StaticResource SettingsCardSpacing}">
            <ui:SettingsCard x:Name="AddAppBarCard" Header="{DynamicResource SettingPaneAppBar_AddAppBarHeader}">
                <Button
                    x:Name="AddAppBarButton"
                    Command="{Binding AddAppBarCommand, Mode=OneTime}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Self}}"
                    Content="{DynamicResource SettingPaneAppBar_AddAppBar}"
                    IsEnabled="{Binding IsInitialized, Mode=OneWay}"
                    Style="{DynamicResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}" />
            </ui:SettingsCard>

            <ikw:SimpleStackPanel
                Margin="{StaticResource SettingsSectionHeaderMargin}"
                Orientation="Horizontal"
                Spacing="{StaticResource SettingsElementsSpacing}">
                <ui:FontIcon
                    VerticalAlignment="Center"
                    FontSize="{StaticResource BodyFontIconFontSize}"
                    Foreground="{StaticResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}"
                    Glyph="&#xE8CB;" />
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{StaticResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}"
                    Text="{DynamicResource SettingPanePlugins_SortBy}" />
                <ComboBox
                    VerticalAlignment="Center"
                    DisplayMemberPath="Display"
                    ItemsSource="{Binding AllSortModes, Mode=OneTime}"
                    SelectedValue="{Binding SortMode, Mode=TwoWay}"
                    SelectedValuePath="Value" />
            </ikw:SimpleStackPanel>

            <ui:ListView
                x:Name="AppBarListView"
                Margin="{StaticResource SettingsSectionHeaderMargin}"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Center"
                dragdrop:DragDropHelper.CanReorderItems="{Binding SortMode, Converter={StaticResource SettingsPaneAppBarSortModeToCanReorderItemsConverter}, Mode=OneWay}"
                dragdrop:DragDropHelper.DropScrollViewer="{Binding ElementName=RootPageScrollViewer, Mode=OneTime}"
                IsSelectionEnabled="False"
                ItemContainerStyle="{StaticResource NoHoverListViewItemStyle}"
                ItemsSource="{Binding AppBars, Mode=OneTime}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ui:ListView.Style>
                    <Style TargetType="ui:ListView">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Items.Count}" Value="0">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <TextBlock
                                                x:Name="NoAppBarsYetTextBlock"
                                                Width="{StaticResource ListViewEmptyTextWidth}"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource {x:Static ui:ThemeKeys.BodyTextBlockStyleKey}}"
                                                Text="{DynamicResource SettingPaneAppBar_NoAppBarsYet}"
                                                TextWrapping="Wrap" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:ListView.Style>
                <ui:ListView.ItemTemplate>
                    <DataTemplate DataType="models:AppBarModel">
                        <ui:SettingsCard
                            x:Name="AppBarSettingsCard"
                            Command="{Binding DataContext.OpenAppBarSettingCommand, RelativeSource={RelativeSource AncestorType=ui:ListView}, Mode=OneTime}"
                            CommandParameter="{Binding ., Mode=OneTime}"
                            Header="{Binding Name, Mode=OneWay}"
                            IsClickEnabled="True"
                            Tag="{Binding ., Mode=OneTime}">
                            <ui:SettingsCard.HeaderIcon>
                                <Image
                                    Width="16"
                                    Height="16"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="{Binding DockMode, Converter={StaticResource DockModeToImageSourceConverter}}" />
                            </ui:SettingsCard.HeaderIcon>

                            <ui:SettingsCard.ActionIcon>
                                <ui:FontIcon Glyph="&#xE76C;" />
                            </ui:SettingsCard.ActionIcon>

                            <ui:ToggleSwitch
                                x:Name="IsEnabledToggleSwitch"
                                IsOn="{Binding IsEnabled, Mode=TwoWay}"
                                OffContent="{DynamicResource ToggleSwitch_OffContent}"
                                OnContent="{DynamicResource ToggleSwitch_OnContent}"
                                Tag="{Binding ., Mode=OneTime}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="Toggled">
                                        <i:InvokeCommandAction Command="{Binding DataContext.IsEnabledToggleSwitchToggledCommand, RelativeSource={RelativeSource AncestorType=ui:ListView}, Mode=OneTime}" CommandParameter="{Binding ElementName=IsEnabledToggleSwitch}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </ui:ToggleSwitch>
                        </ui:SettingsCard>
                    </DataTemplate>
                </ui:ListView.ItemTemplate>
            </ui:ListView>
        </ikw:SimpleStackPanel>
    </ui:ScrollViewerEx>
</ui:Page>