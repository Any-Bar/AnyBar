<ui:Page
    x:Class="AnyBar.Views.SettingsPaneAbout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:AnyBar.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:AnyBar.ViewModels"
    Title="{DynamicResource SettingWindow_About}"
    d:DataContext="{d:DesignInstance Type=viewmodels:SettingsPaneAboutViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ui:ScrollViewerEx
        x:Name="RootPageScrollViewer"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <ikw:SimpleStackPanel
            Margin="{StaticResource PageScrollViewerContentMargin}"
            Orientation="Vertical"
            Spacing="{StaticResource SettingsCardSpacing}">
            <TextBlock Style="{StaticResource SettingsFirstSectionHeaderTextBlockStyle}" Text="App" />
            <ui:SettingsCard Description="{DynamicResource SettingPaneAbout_Version}" Header="{Binding Version}">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Glyph="&#xe946;" />
                </ui:SettingsCard.HeaderIcon>
            </ui:SettingsCard>

            <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Related" />
            <ui:SettingsCard Header="Click to support">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Glyph="&#xe946;" />
                </ui:SettingsCard.HeaderIcon>
            </ui:SettingsCard>
        </ikw:SimpleStackPanel>
    </ui:ScrollViewerEx>
</ui:Page>